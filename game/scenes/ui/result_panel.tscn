[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/result_panel.gd" id="1_result"]

[node name="ResultPanel" type="CanvasLayer"]
script = ExtResource("1_result")

[node name="panel" type="Panel" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -260.0
offset_top = -210.0
offset_right = 260.0
offset_bottom = 210.0

[node name="vbox" type="VBoxContainer" parent="panel"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 25.0
offset_top = 20.0
offset_right = -25.0
offset_bottom = -20.0
theme_override_constants/separation = 10

[node name="title_label" type="Label" parent="panel/vbox"]
layout_mode = 2
text = "任务完成"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 30

[node name="rewards_label" type="Label" parent="panel/vbox"]
layout_mode = 2
text = ""
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(1, 0.8, 0.2, 1)

[node name="stats_label" type="Label" parent="panel/vbox"]
layout_mode = 2
text = "击杀: 0 | 等级: 1"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14

[node name="spacer" type="Control" parent="panel/vbox"]
layout_mode = 2
size_flags_vertical = 3

[node name="restart_button" type="Button" parent="panel/vbox"]
layout_mode = 2
text = "重新挑战"
size_flags_horizontal = 4

[node name="quit_button" type="Button" parent="panel/vbox"]
layout_mode = 2
text = "返回事务所"

[connection signal="pressed" from="panel/vbox/restart_button" to="." method="_on_restart_pressed"]
[connection signal="pressed" from="panel/vbox/quit_button" to="." method="_on_quit_pressed"]
